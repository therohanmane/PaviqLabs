# Server
PORT=5000
NODE_ENV=development

# MongoDB (use MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/paviqlabs?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email (Nodemailer - use Gmail app password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Recipient email (where inquiries go)
CONTACT_TO_EMAIL=info@paviqlabs.in
CONTACT_FROM_NAME=PaviqLabs Website

# Admin credentials (change before deploy!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PaviqLabs@2025
